#!/usr/bin/env python3
"""beamtimehero — autonomous CLI: upstream parser + autonomy extensions.

Composes the upstream `beamtimehero_cli.cli.__main__` helpers with three
autonomy-specific additions:

  * a `steering` subtree (intervention queue lifecycle),
  * per-agent-role argparse branches (blaligner / samplealigner /
    collector / surveyor) that filter the spec-write subtree and validate
    motor args against `beamline_tools.agent_roles.AGENT_ROLES`,
  * autonomy reference docs registered with upstream's `refdocs` registry.

Discover via `--help` at any depth. Errors → JSON
`{"ok": false, "error": "..."}` on stdout, non-zero exit. Successful tool
calls print the tool's stdout (image paths included) and exit 0.
"""
from __future__ import annotations

import argparse
import json
import os
import sys
import traceback
from pathlib import Path

# ---------------------------------------------------------------------------
# Path bootstrap — make this script invokable from anywhere.
# ---------------------------------------------------------------------------
HERE = Path(__file__).resolve().parent
ROOT = HERE.parent
sys.path.insert(0, str(ROOT))

# Simulation bootstrap MUST happen before any beamline_tools / beamtimehero_cli
# import, because they read SPEC_MOCK / BL_SCAN_DIR / BL_LOGS_DIR at import time.
if os.getenv("SPEC_MOCK", "1") != "0":
    try:
        import simulation  # type: ignore
        simulation.bootstrap()
    except Exception as e:  # noqa: BLE001
        print(f"warning: simulation bootstrap failed: {e}", file=sys.stderr)

# Importing orchestration wires the autonomy CAT-8 surface into tool_catalog.
try:
    import orchestration  # noqa: F401
except Exception as e:  # noqa: BLE001
    print(f"warning: orchestration import failed: {e}", file=sys.stderr)

from beamtimehero_cli import refdocs  # noqa: E402
from beamtimehero_cli.cli.__main__ import (  # noqa: E402
    ToolParser,
    build_catalog_subtrees,
    build_ref_subtree,
    run_ref,
    run_tool_leaf,
    run_with,
)
from beamline_tools.agent_roles import AGENT_ROLES, agent_motor_allowed  # noqa: E402
from beamline_tools.tool_catalog import TOOL_DEFINITIONS  # noqa: E402

# ---------------------------------------------------------------------------
# Patch upstream's categorize + executor to see autonomy's orchestration tools.
# Upstream's categorize() imports TOOL_LINEAGE from its own package, missing
# autonomy's "autonomy_db" entries — so orchestration tools land under ("tool",)
# instead of ("db",).  Upstream's executor dispatches through a tree-keyed
# DISPATCH that has no orchestration handlers.  These two patches bridge the
# gap without modifying the upstream package.
# ---------------------------------------------------------------------------
import beamtimehero_cli.tool_catalog.categorize as _cat_mod          # noqa: E402
_cat_mod.TOOL_LINEAGE = __import__(                                   # noqa: E402
    "beamline_tools.tool_catalog.lineage", fromlist=["TOOL_LINEAGE"]
).TOOL_LINEAGE

import beamtimehero_cli.cli.__main__ as _cli_mod                     # noqa: E402
_cli_mod.execute_tool = __import__(                                   # noqa: E402
    "beamline_tools.tool_catalog.executor", fromlist=["execute_tool"]
).execute_tool

CONTEXT_DIR = ROOT / "context"


# ---------------------------------------------------------------------------
# Autonomy refdocs — registered against upstream's registry at startup.
# ---------------------------------------------------------------------------

_AUTONOMY_REFDOCS: list[tuple[str, str, str]] = [
    ("agent-instructions", ".claude/prompts/base-layer.md",
     "Mandatory base-layer instructions every autonomous agent must follow."),
    ("cryostat-procedures", ".claude/skills/cryostat-procedures/SKILL.md",
     "Liquid helium cryostat operating procedures and safety rules."),
    ("changing-energy", ".claude/skills/changing-energy/SKILL.md",
     "Minimal procedure for switching between absorption edges."),
    ("energy-calibration", ".claude/skills/energy-calibration/SKILL.md",
     "Mono energy calibration via reference foil."),
    ("beamline-alignment", ".claude/skills/beamline-alignment/SKILL.md",
     "Beamline alignment session notes with lessons learned."),
    ("spectrometer-alignment", ".claude/skills/spectrometer-alignment/SKILL.md",
     "Procedure for aligning the 7-crystal HERFD spectrometer."),
    ("sample-alignment", ".claude/skills/sample-alignment/SKILL.md",
     "Procedure for aligning the cryostat sample holder."),
    ("sample-data-collection", ".claude/skills/sample-data-collection/SKILL.md",
     "Procedure for collecting HERFD spectra spot-by-spot."),
    ("spec-reference", ".claude/skills/spec-reference/SKILL.md",
     "SPEC protocol reference for BL15-2."),
    ("user-reference", ".claude/skills/user-reference/SKILL.md",
     "User guide for BL15-2."),
]


def _register_autonomy_refdocs() -> None:
    for name, rel_path, description in _AUTONOMY_REFDOCS:
        refdocs.register_doc(name, ROOT / rel_path, description)


# ---------------------------------------------------------------------------
# Domain-specific argparse error hint
# ---------------------------------------------------------------------------

def _argparse_error_hint(message: str) -> str | None:
    if "--element" in message and "unrecognized" in message.lower():
        return (
            "Element is set via `spec-write select-element --element <X>` "
            "(or via the optional `--element` arg on `spec-write run-xas`). "
            "Other tools take the element implicitly from the current SPEC state."
        )
    return None


class _HintingToolParser(ToolParser):
    """ToolParser with an autonomy-side domain hint on argparse errors."""

    def error(self, message: str) -> None:  # type: ignore[override]
        hint = _argparse_error_hint(message)
        payload: dict = {"ok": False, "error": f"argparse: {message}"}
        if hint:
            payload["hint"] = hint
        print(json.dumps(payload))
        sys.exit(2)


# ---------------------------------------------------------------------------
# Steering subtree
# ---------------------------------------------------------------------------

def _build_steering_subtree(subs: argparse._SubParsersAction) -> None:
    steering_tree = subs.add_parser(
        "steering",
        help="Staff-guidance lifecycle: list/ack/comment/complete/defer pending rows.",
    )
    steering_subs = steering_tree.add_subparsers(dest="leaf", metavar="<command>")

    s_pending = steering_subs.add_parser(
        "pending",
        help="List pending steering rows (completed_at IS NULL) as a JSON array.",
    )
    s_pending.add_argument("--experiment-id", dest="experiment_id", default=None,
                          help="Filter to a specific experiment.")
    s_pending.add_argument("--unacked", action="store_true",
                          help="Only rows the active agent has not yet acked.")

    s_ack = steering_subs.add_parser(
        "ack", help="Set active_agent_ack_at on a steering row.")
    s_ack.add_argument("id", help="Steering ID.")
    s_ack.add_argument("--agent-run-id", dest="agent_run_id", default=None,
                      help="Link this ack to an AgentRun (defaults to $BEAMTIMEHERO_AGENT_RUN_ID).")

    s_comment = steering_subs.add_parser(
        "set-comment", help="Write ack_comment on a steering row.")
    s_comment.add_argument("id", help="Steering ID.")
    s_comment.add_argument("text", help="Comment text.")

    s_complete = steering_subs.add_parser(
        "complete", help="Mark a steering row complete: write result + completed_at.")
    s_complete.add_argument("id", help="Steering ID.")
    s_complete.add_argument("--result", required=True,
                           help="Result text returned to the orchestrator.")

    s_defer = steering_subs.add_parser(
        "defer", help="Defer a steering row (ack_comment, no completed_at).")
    s_defer.add_argument("id", help="Steering ID.")
    s_defer.add_argument("--reason", required=True, help="Why this row is being deferred.")
    s_defer.add_argument(
        "--target", dest="target", default=None,
        choices=["planner", "beamline_alignment", "sample_alignment",
                 "sample_survey", "collection"],
        help="Agent type the orchestrator should re-dispatch this row to.",
    )


def _run_steering(args: argparse.Namespace) -> int:
    from beamline_tools.steering import cli as steering_cli

    leaf = getattr(args, "leaf", None)
    handlers = {
        "pending": steering_cli.cmd_pending,
        "ack": steering_cli.cmd_ack,
        "set-comment": steering_cli.cmd_set_comment,
        "complete": steering_cli.cmd_complete,
        "defer": steering_cli.cmd_defer,
    }
    handler = handlers.get(leaf)
    if handler is None:
        print(json.dumps({"ok": False, "error": f"unknown steering subcommand: {leaf!r}"}))
        return 2
    try:
        return handler(args)
    except Exception as e:  # noqa: BLE001
        traceback.print_exc(file=sys.stderr)
        print(json.dumps({"ok": False, "error": str(e)}, default=str))
        return 1


# ---------------------------------------------------------------------------
# Agent-role branches
# ---------------------------------------------------------------------------

def _filter_for_role(spec_write_filter: frozenset[str]) -> list[dict]:
    """Pre-filter TOOL_DEFINITIONS: keep non-spec-write tools, plus spec-write
    tools that the role is allowed to invoke."""
    filtered: list[dict] = []
    for tdef in TOOL_DEFINITIONS:
        fn = tdef.get("function") or {}
        name = fn.get("name")
        params = fn.get("parameters") or {}
        required = set(params.get("required") or [])
        is_spec_write = "justification" in required
        if is_spec_write and name not in spec_write_filter:
            continue
        filtered.append(tdef)
    return filtered


def _stamp_agent_role(subs: argparse._SubParsersAction, role_name: str) -> None:
    """Walk the subparsers built by build_catalog_subtrees and add the
    `_agent_role` default to every leaf, so _run_tool_leaf can enforce the
    motor allowlist for this role."""
    for tree_name in ("tool", "db", "spec-read", "spec-write"):
        tree_parser = subs.choices.get(tree_name)
        if tree_parser is None:
            continue
        for action in tree_parser._actions:
            if isinstance(action, argparse._SubParsersAction):
                for leaf_parser in action.choices.values():
                    leaf_parser.set_defaults(_agent_role=role_name)


def _build_role_branch(subs: argparse._SubParsersAction, role_name: str, role_def: dict) -> None:
    branch = subs.add_parser(
        role_name,
        help=(f"Agent scope: {role_name} (phase={role_def['phase']}). "
              "Filters spec-write tools and validates motor args."),
    )
    branch_subs = branch.add_subparsers(dest="subtree", metavar="<tree>")
    build_ref_subtree(branch_subs)
    build_catalog_subtrees(branch_subs, _filter_for_role(role_def["spec_write_tools"]))
    _stamp_agent_role(branch_subs, role_name)
    _build_steering_subtree(branch_subs)


# ---------------------------------------------------------------------------
# Tool-leaf dispatch with motor allowlist guard
# ---------------------------------------------------------------------------

def _run_tool_leaf(args: argparse.Namespace) -> int:
    role = getattr(args, "_agent_role", None)
    if role:
        for key in ("motor", "motor1", "motor2"):
            motor_val = getattr(args, key, None)
            if motor_val and not agent_motor_allowed(role, motor_val):
                allowed = sorted(AGENT_ROLES[role]["motors"])
                print(json.dumps({
                    "ok": False,
                    "error": f"motor {motor_val!r} not in {role} allowed set",
                    "agent_role": role,
                    "allowed_motors": allowed,
                }))
                return 1
    return run_tool_leaf(args)


# ---------------------------------------------------------------------------
# Parser + dispatcher
# ---------------------------------------------------------------------------

def _build_parser() -> argparse.ArgumentParser:
    _register_autonomy_refdocs()
    parser = _HintingToolParser(
        prog="beamtimehero",
        description=(
            "Unified beamline CLI. Discover trees with `beamtimehero --help`; "
            "leaves with `beamtimehero <tree> <cmd> --help`."
        ),
    )
    trees = parser.add_subparsers(dest="tree", metavar="<tree>")

    # Upstream subtrees: ref / tool / db / spec-read / spec-write
    build_ref_subtree(trees)
    build_catalog_subtrees(trees, TOOL_DEFINITIONS)
    # Autonomy steering subtree
    _build_steering_subtree(trees)

    # Agent branches: lazy — build leaves only for the role named in sys.argv[1].
    # Other roles get placeholder parsers so top-level --help lists them all.
    first_token = sys.argv[1] if len(sys.argv) >= 2 else None
    for role_name, role_def in AGENT_ROLES.items():
        if first_token == role_name:
            _build_role_branch(trees, role_name, role_def)
        else:
            trees.add_parser(
                role_name,
                help=f"Agent scope: {role_name} (phase={role_def['phase']}).",
            )
    return parser


def _dispatch(parser: argparse.ArgumentParser, args: argparse.Namespace) -> int:
    if not getattr(args, "tree", None):
        parser.print_help()
        return 0

    # Agent-role branch
    if args.tree in AGENT_ROLES:
        subtree = getattr(args, "subtree", None)
        if not subtree:
            parser.parse_args([args.tree, "--help"])
            return 0
        if subtree == "ref":
            return run_ref(args)
        if subtree == "steering":
            if not getattr(args, "leaf", None):
                parser.parse_args([args.tree, subtree, "--help"])
                return 0
            return _run_steering(args)
        if not getattr(args, "leaf", None):
            parser.parse_args([args.tree, subtree, "--help"])
            return 0
        return _run_tool_leaf(args)

    if args.tree == "ref":
        return run_ref(args)
    if args.tree == "steering":
        if not getattr(args, "leaf", None):
            parser.parse_args([args.tree, "--help"])
            return 0
        return _run_steering(args)
    if not getattr(args, "leaf", None):
        parser.parse_args([args.tree, "--help"])
        return 0
    return _run_tool_leaf(args)


_KNOWN_TREES = frozenset(
    {"ref", "tool", "db", "spec-read", "spec-write", "steering"} | set(AGENT_ROLES.keys())
)


def main(argv: list[str] | None = None) -> int:
    # Seed runtime_state from the active experiment so action-log + tools that
    # consult get_experiment_id() pick the right context. Best-effort: a
    # missing DB / no active experiment must not block --help paths.
    try:
        from orchestration import runtime_state as _runtime_state
        from orchestration.plan_store.session import get_active_experiment
        from orchestration.plan_store.client import get_plan

        _exp = get_active_experiment()
        if _exp is not None:
            _plan = get_plan(_exp.id) or {}
            _runtime_state.set_phase(_plan.get("phase") or "setup", experiment_id=_exp.id)
    except Exception:
        pass

    return run_with(_build_parser, _dispatch, argv, known_trees=_KNOWN_TREES)


if __name__ == "__main__":
    sys.exit(main())
