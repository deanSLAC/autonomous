#!/usr/bin/env python3
"""beamtimehero — unified CLI for the autonomous beamline agent.

Surfaces the full beamline_tools catalog to a Claude Code agent via
claude code's built-in Bash tool. Single binary, scope-segmented:

    beamtimehero ref         — reference docs from context/
    beamtimehero tool        — non-SPEC tools (data, logs, analysis,
                               plots, file I/O)
    beamtimehero db          — database tools (experiment plan, budget,
                               sample progress, guidance, interventions)
    beamtimehero spec-read   — SPEC-bound reads (motor positions, beam
                               status, scan number)
    beamtimehero spec-write  — SPEC-bound mutations. Every leaf
                               requires --justification.

Discover via `--help` at any depth. `tool` / `spec-read` / `spec-write`
leaves are autogenerated from beamline_tools.tool_catalog.TOOL_DEFINITIONS;
`ref` is hand-written and reuses REFERENCE_DOCS from
beamline_tools.tool_catalog.cli (single source of truth).

Errors → JSON {"ok": false, "error": "..."} on stdout, non-zero exit.
Successful tool calls print the tool's stdout (image paths included)
and exit 0.
"""
from __future__ import annotations

import argparse
import io
import json
import os
import sys
import time
import traceback
from pathlib import Path

# ---------------------------------------------------------------------------
# Path bootstrap — make this script invokable from anywhere
# ---------------------------------------------------------------------------
HERE = Path(__file__).resolve().parent
ROOT = HERE.parent
sys.path.insert(0, str(ROOT))

# Simulation bootstrap MUST happen before bl_config / beamline_tools imports,
# because they read SPEC_MOCK / BL_SCAN_DIR / BL_LOGS_DIR at import time.
# Skip entirely when SPEC_MOCK=0 so we never touch the sandbox or mock paths.
if os.getenv("SPEC_MOCK", "1") != "0":
    try:
        import simulation  # type: ignore
        simulation.bootstrap()
    except Exception as e:  # noqa: BLE001
        print(f"warning: simulation bootstrap failed: {e}", file=sys.stderr)

# Importing orchestration registers CAT-8 plan tools into the catalog.
try:
    import orchestration  # noqa: F401
except Exception as e:  # noqa: BLE001
    print(f"warning: orchestration import failed: {e}", file=sys.stderr)

from beamline_tools.tool_catalog import TOOL_DEFINITIONS, execute_tool  # noqa: E402
from beamline_tools.tool_catalog.cli import REFERENCE_DOCS  # noqa: E402
from beamline_tools.tool_catalog.lineage import TOOL_LINEAGE  # noqa: E402

CONTEXT_DIR = ROOT / "context"


# ---------------------------------------------------------------------------
# Categorization
# ---------------------------------------------------------------------------
# Four trees + ref. A tool's tree is derived from existing data:
#   * source == "autonomy_db" in lineage → db
#   * "justification" required           → spec-write
#   * spec_command in TOOL_LINEAGE       → spec-read
#   * else                               → tool
# Override map below covers any mixed cases that need explicit placement.

CATEGORY_OVERRIDES: dict[str, str] = {
    # No overrides currently required — derivation is correct for every
    # tool in the catalog. Add entries here as ("tool_name": "tree") pairs
    # if a future tool's category needs to disagree with the rule.
}


def _categorize(tool_def: dict) -> str:
    name = tool_def["function"]["name"]
    if name in CATEGORY_OVERRIDES:
        return CATEGORY_OVERRIDES[name]
    lineage = TOOL_LINEAGE.get(name) or {}
    if lineage.get("source") == "autonomy_db":
        return "db"
    params = tool_def["function"].get("parameters", {}) or {}
    required = set(params.get("required", []) or [])
    if "justification" in required:
        return "spec-write"
    spec_cmd = lineage.get("spec_command")
    if spec_cmd is not None:
        return "spec-read"
    return "tool"


# ---------------------------------------------------------------------------
# JSON-schema → argparse mapping
# ---------------------------------------------------------------------------

_BOOL_TRUE = {"true", "yes", "on", "1"}
_BOOL_FALSE = {"false", "no", "off", "0"}


def _bool_from_str(s: str) -> bool:
    sl = s.strip().lower()
    if sl in _BOOL_TRUE:
        return True
    if sl in _BOOL_FALSE:
        return False
    raise argparse.ArgumentTypeError(f"expected boolean (true/false), got {s!r}")


def _json_arg(s: str):
    """Decode a JSON-encoded array/object arg."""
    try:
        return json.loads(s)
    except json.JSONDecodeError as e:
        raise argparse.ArgumentTypeError(f"expected JSON, got {s!r}: {e}") from e


def _add_arg(p: argparse.ArgumentParser, key: str, prop: dict, required: bool) -> None:
    """Add one argparse flag derived from a JSON-schema property."""
    flag = f"--{key.replace('_', '-')}"
    desc = (prop.get("description") or "").strip()
    kwargs: dict = {"help": desc}
    if "default" in prop:
        kwargs["default"] = prop["default"]
    if required:
        kwargs["required"] = True

    enum = prop.get("enum")
    if enum:
        kwargs["choices"] = [str(v) for v in enum]
        p.add_argument(flag, **kwargs)
        return

    t = prop.get("type", "string")
    if t == "integer":
        kwargs["type"] = int
        p.add_argument(flag, **kwargs)
    elif t == "number":
        kwargs["type"] = float
        p.add_argument(flag, **kwargs)
    elif t == "boolean":
        kwargs["type"] = _bool_from_str
        kwargs["metavar"] = "BOOL"
        p.add_argument(flag, **kwargs)
    elif t in ("array", "object"):
        kwargs["type"] = _json_arg
        kwargs["metavar"] = "JSON"
        p.add_argument(flag, **kwargs)
    else:  # string / unknown
        p.add_argument(flag, **kwargs)


# ---------------------------------------------------------------------------
# Build the parser
# ---------------------------------------------------------------------------

# argparse exits with rc=2 on parse errors. We override to print the JSON
# error envelope our tool layer uses elsewhere, so claude code's Bash tool
# sees a consistent shape.
class _ToolParser(argparse.ArgumentParser):
    def error(self, message: str) -> None:  # type: ignore[override]
        print(json.dumps({"ok": False, "error": f"argparse: {message}"}))
        sys.exit(2)


def _build_parser() -> argparse.ArgumentParser:
    parser = _ToolParser(
        prog="beamtimehero",
        description=(
            "Unified beamline CLI. Discover trees with `beamtimehero --help`; "
            "leaves with `beamtimehero <tree> <cmd> --help`."
        ),
    )
    trees = parser.add_subparsers(dest="tree", metavar="<tree>")

    # ---- ref: reference docs -------------------------------------------
    ref = trees.add_parser(
        "ref",
        help="Reference docs (use `ref --list` to enumerate, `ref <name>` to fetch).",
    )
    ref.add_argument("doc_name", nargs="?", help="Reference document name.")
    ref.add_argument(
        "--list", action="store_true", dest="list_docs",
        help="List all available reference documents.",
    )

    # ---- tool / db / spec-read / spec-write: autogenerated --------------
    tool_tree = trees.add_parser(
        "tool",
        help="Non-SPEC tools: data queries, analysis, plotting, file I/O.",
    )
    db_tree = trees.add_parser(
        "db",
        help="Database tools: experiment plan, beamtime budget, sample progress, guidance, interventions.",
    )
    spec_read_tree = trees.add_parser(
        "spec-read",
        help="SPEC-bound reads (motor positions, beam status). No mutation.",
    )
    spec_write_tree = trees.add_parser(
        "spec-write",
        help="SPEC-bound mutations. Every leaf requires --justification.",
    )

    # ---- steering: bespoke staff-guidance lifecycle -------------------
    # Leaves are hand-written (not auto-generated from TOOL_DEFINITIONS) since
    # they manipulate StaffGuidance lifecycle columns rather than calling tools.
    steering_tree = trees.add_parser(
        "steering",
        help="Staff-guidance lifecycle: list/ack/comment/complete/defer pending rows.",
    )
    steering_subs = steering_tree.add_subparsers(dest="leaf", metavar="<command>")

    s_pending = steering_subs.add_parser(
        "pending",
        help="List pending steering rows (completed_at IS NULL) as a JSON array.",
    )
    s_pending.add_argument(
        "--experiment-id", dest="experiment_id", default=None,
        help="Filter to a specific experiment.",
    )
    s_pending.add_argument(
        "--unacked", action="store_true",
        help="Only rows the active agent has not yet acked.",
    )

    s_ack = steering_subs.add_parser(
        "ack",
        help="Set active_agent_ack_at on a steering row; optionally link agent_run_id.",
    )
    s_ack.add_argument("id", help="Steering ID.")
    s_ack.add_argument(
        "--agent-run-id", dest="agent_run_id", default=None,
        help="Link this ack to an AgentRun (defaults to $BEAMTIMEHERO_AGENT_RUN_ID).",
    )

    s_comment = steering_subs.add_parser(
        "set-comment",
        help="Write ack_comment on a steering row.",
    )
    s_comment.add_argument("id", help="Steering ID.")
    s_comment.add_argument("text", help="Comment text.")

    s_complete = steering_subs.add_parser(
        "complete",
        help="Mark a steering row complete: write result + completed_at.",
    )
    s_complete.add_argument("id", help="Steering ID.")
    s_complete.add_argument(
        "--result", required=True,
        help="Result text returned to the orchestrator.",
    )

    s_defer = steering_subs.add_parser(
        "defer",
        help="Defer a steering row (write 'deferred — <reason>' ack_comment, no completed_at).",
    )
    s_defer.add_argument("id", help="Steering ID.")
    s_defer.add_argument(
        "--reason", required=True,
        help="Why this row is being deferred.",
    )

    tool_subs = tool_tree.add_subparsers(dest="leaf", metavar="<command>")
    db_subs = db_tree.add_subparsers(dest="leaf", metavar="<command>")
    spec_read_subs = spec_read_tree.add_subparsers(dest="leaf", metavar="<command>")
    spec_write_subs = spec_write_tree.add_subparsers(dest="leaf", metavar="<command>")
    bucket = {
        "tool": tool_subs,
        "db": db_subs,
        "spec-read": spec_read_subs,
        "spec-write": spec_write_subs,
    }

    for tdef in TOOL_DEFINITIONS:
        fn = tdef.get("function") or {}
        name = fn.get("name")
        if not name:
            continue
        category = _categorize(tdef)
        params = fn.get("parameters") or {}
        properties = params.get("properties") or {}
        required = set(params.get("required") or [])
        description = (fn.get("description") or "").strip()

        cli_name = name.replace("_", "-")
        leaf = bucket[category].add_parser(cli_name, help=description)
        # Stash the canonical tool name for dispatch (cli_name is kebab,
        # underlying tool is snake).
        leaf.set_defaults(_tool_name=name, _tool_category=category)
        for key, prop in properties.items():
            _add_arg(leaf, key, prop or {}, key in required)

    return parser


# ---------------------------------------------------------------------------
# Subcommand dispatch
# ---------------------------------------------------------------------------

def _print_doc_index() -> int:
    lines = ["Available reference documents:", ""]
    for name, info in REFERENCE_DOCS.items():
        lines.append(f"  {name:25s} {info['description']}")
    lines.append("")
    lines.append("Usage: beamtimehero ref <doc-name>")
    print("\n".join(lines))
    return 0


def _run_ref(args: argparse.Namespace) -> int:
    if args.list_docs or not args.doc_name:
        return _print_doc_index()
    name = args.doc_name
    if name not in REFERENCE_DOCS:
        print(json.dumps({
            "ok": False,
            "error": (f"unknown reference '{name}'. "
                      f"Run `beamtimehero ref --list` to see available docs."),
        }))
        return 1
    fp = CONTEXT_DIR / REFERENCE_DOCS[name]["file"]
    try:
        print(fp.read_text())
        return 0
    except FileNotFoundError:
        print(json.dumps({
            "ok": False,
            "error": f"reference file not found: {fp}",
        }))
        return 1


def _run_tool_leaf(args: argparse.Namespace) -> int:
    name = args._tool_name
    # Walk argparse Namespace, build the args dict, skipping framework fields.
    framework_keys = {"tree", "leaf", "_tool_name", "_tool_category"}
    payload: dict = {}
    for k, v in vars(args).items():
        if k in framework_keys:
            continue
        if v is None:
            # Argparse omits keys with no default; we exclude None to keep
            # the payload identical to what the LLM would build natively
            # (avoid sending {arg: null}).
            continue
        payload[k] = v

    try:
        text, images = execute_tool(name, payload)
    except Exception as e:  # noqa: BLE001
        traceback.print_exc(file=sys.stderr)
        print(json.dumps({"ok": False, "error": str(e)}, default=str))
        return 1

    if images:
        # Persist any base64 images to disk (mirrors tool_dispatcher.py).
        try:
            import base64
            from datetime import datetime
            out_dir = ROOT / "data" / "tool_plots"
            out_dir.mkdir(parents=True, exist_ok=True)
            paths: list[str] = []
            for i, b64 in enumerate(images):
                fn = out_dir / f"{name}_{datetime.now():%Y%m%d_%H%M%S_%f}_{i}.png"
                fn.write_bytes(base64.b64decode(b64))
                paths.append(str(fn))
            payload_out = {
                "text": text,
                "plot_path": paths[0] if paths else None,
                "image_paths": paths,
            }
            print(json.dumps(payload_out, default=str))
            return 0
        except Exception as e:  # noqa: BLE001
            print(json.dumps({"text": text, "image_error": str(e)}, default=str))
            return 0

    print(text if isinstance(text, str) else json.dumps(text, default=str))
    return 0


_KNOWN_TREES = frozenset({"ref", "tool", "db", "spec-read", "spec-write", "steering"})


# ---------------------------------------------------------------------------
# Steering dispatch
# ---------------------------------------------------------------------------

def _run_steering(args: argparse.Namespace) -> int:
    """Dispatch the `beamtimehero steering <leaf>` subtree."""
    from beamline_tools.steering import cli as steering_cli

    leaf = getattr(args, "leaf", None)
    handlers = {
        "pending": steering_cli.cmd_pending,
        "ack": steering_cli.cmd_ack,
        "set-comment": steering_cli.cmd_set_comment,
        "complete": steering_cli.cmd_complete,
        "defer": steering_cli.cmd_defer,
    }
    handler = handlers.get(leaf)
    if handler is None:
        print(json.dumps({
            "ok": False,
            "error": f"unknown steering subcommand: {leaf!r}",
        }))
        return 2
    try:
        return handler(args)
    except Exception as e:  # noqa: BLE001
        traceback.print_exc(file=sys.stderr)
        print(json.dumps({"ok": False, "error": str(e)}, default=str))
        return 1


# ---------------------------------------------------------------------------
# stdout tee — capture what the CLI prints so the cli_log can store it
# ---------------------------------------------------------------------------

class _TeeStdout(io.TextIOBase):
    """Forward writes to the real stdout AND a capture buffer.

    Buffer is kept bounded by trimming to the last `max_bytes` after each
    write — we want the *tail* (errors and JSON envelopes land at the end).
    """

    def __init__(self, real, max_bytes: int) -> None:
        self._real = real
        self._buf = io.StringIO()
        self._max = max_bytes

    def write(self, s):  # noqa: D401
        self._real.write(s)
        self._buf.write(s)
        # Trim to keep memory bounded for image-heavy plot tools.
        cur = self._buf.getvalue()
        if len(cur) > self._max * 2:
            self._buf = io.StringIO()
            self._buf.write(cur[-self._max:])
        return len(s)

    def flush(self):
        self._real.flush()

    def captured(self) -> str:
        s = self._buf.getvalue()
        return s[-self._max:] if len(s) > self._max else s

    def isatty(self):
        try:
            return self._real.isatty()
        except Exception:
            return False


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def _dispatch(parser: argparse.ArgumentParser, args: argparse.Namespace) -> int:
    """Dispatch already-parsed args. Returns exit code."""
    if not getattr(args, "tree", None):
        parser.print_help()
        return 0

    if args.tree == "ref":
        return _run_ref(args)

    if args.tree == "steering":
        if not getattr(args, "leaf", None):
            parser.parse_args([args.tree, "--help"])
            return 0  # argparse exits on --help
        return _run_steering(args)

    if not getattr(args, "leaf", None):
        # Bare `beamtimehero tool` / `spec-read` / `spec-write` with no leaf.
        # Re-run with --help on the tree's parser so the agent gets the list.
        parser.parse_args([args.tree, "--help"])
        return 0  # argparse exits on --help

    return _run_tool_leaf(args)


def main(argv: list[str] | None = None) -> int:
    # Each beamtimehero call is a fresh subprocess (claude code spawns one
    # per tool call), so _PHASE_STATE starts empty. Pull the active
    # experiment + phase from the DB so phase-gated tools and tools that
    # call spec_cmd.get_experiment_id() (e.g. get_experiment_config) work.
    # Mirrors scripts/tool_dispatcher.py.
    try:
        from beamline_tools.spec_control import spec_cmd as _spec_cmd_bootstrap
        from orchestration.plan_store.session import get_active_experiment
        from orchestration.plan_store.client import get_experiment_plan

        _exp = get_active_experiment()
        if _exp is not None:
            _plan = get_experiment_plan(_exp.id) or {}
            _phase = _plan.get("phase") or "setup"
            _spec_cmd_bootstrap.set_phase(_phase, experiment_id=_exp.id)
    except Exception:
        # Best-effort — do not block --help or non-experiment paths.
        pass

    phase_override = os.environ.get("SPEC_PHASE_OVERRIDE")
    if phase_override:
        from beamline_tools.spec_control import spec_cmd
        spec_cmd.set_phase(phase_override)

    raw_argv = list(sys.argv[1:]) if argv is None else list(argv)

    # Lazy-import to avoid pulling SQLModel into --help paths if logging
    # is disabled (and to keep the failure mode local).
    try:
        from beamline_tools.config import CLI_LOG_ENABLED, CLI_LOG_MAX_RESULT_BYTES, SPEC_MOCK
        log_enabled = CLI_LOG_ENABLED
        max_bytes = CLI_LOG_MAX_RESULT_BYTES
        spec_mock_flag = 1 if SPEC_MOCK else 0
    except Exception:
        log_enabled = False
        max_bytes = 65536
        spec_mock_flag = None

    if not log_enabled:
        parser = _build_parser()
        args = parser.parse_args(argv)
        return _dispatch(parser, args)

    started = time.monotonic()
    real_stdout = sys.stdout
    tee = _TeeStdout(real_stdout, max_bytes)
    sys.stdout = tee

    parsed: argparse.Namespace | None = None
    rc = 0
    error_message: str | None = None
    try:
        try:
            parser = _build_parser()
            parsed = parser.parse_args(argv)
            rc = _dispatch(parser, parsed)
        except SystemExit as e:
            # argparse calls sys.exit() on --help (rc=0) and parse errors (rc=2).
            # _ToolParser.error() also lands here. Capture and re-raise.
            rc = int(e.code) if isinstance(e.code, int) else (0 if e.code is None else 1)
            raise
        except Exception as e:  # noqa: BLE001 — surface as nonzero, log, re-raise
            rc = 1
            error_message = f"{type(e).__name__}: {e}"
            raise
    finally:
        sys.stdout = real_stdout
        latency_ms = int((time.monotonic() - started) * 1000)
        try:
            from beamline_tools.action_log.cli_log import record_cli_invocation
            # Best-effort fallback for paths where argparse SystemExit fires
            # during parse_args (e.g. `tool --help`) before we see a Namespace.
            tree_hint = raw_argv[0] if raw_argv and raw_argv[0] in _KNOWN_TREES else None
            tree = getattr(parsed, "tree", None) if parsed is not None else tree_hint
            leaf = getattr(parsed, "leaf", None) if parsed is not None else None
            tool_name = getattr(parsed, "_tool_name", None) if parsed is not None else None
            justification = getattr(parsed, "justification", None) if parsed is not None else None
            record_cli_invocation(
                argv=raw_argv,
                tree=tree,
                leaf=leaf,
                tool_name=tool_name,
                justification=justification,
                exit_code=rc,
                latency_ms=latency_ms,
                stdout_tail=tee.captured() or None,
                error_message=error_message,
                spec_mock=spec_mock_flag,
            )
        except Exception:  # noqa: BLE001 — never break the CLI
            pass

    return rc


if __name__ == "__main__":
    sys.exit(main())
