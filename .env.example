# ============================================================================
# Autonomous Beamline Agent — configuration
#
# This file is the ONE place to configure the app. Copy it to .env and edit.
# Everything the app reads at runtime is here. Code defaults do not exist.
# If a required value below is missing from your .env, the app will fail
# loudly at startup naming the variable.
# ============================================================================

# ---- Agent backend ---------------------------------------------------------
# claude_code — `claude -p` subprocess per turn (no harness server)
# opencode    — opencode HTTP server on loopback :4096
AGENT_BACKEND=claude_code

# ---- LLM gateway (claude_code path only; opencode reads opencode.json) -----
# slac     — SLAC AI Gateway
# stanford — Stanford AI Playground
# default  — leave claude code's own auth (personal OAuth) in place
LLM_GATEWAY=slac

# Optional explicit model alias passed to `claude -p --model`. Empty means
# use the gateway's MODEL_ALIAS below.
CLAUDE_MODEL=

# ---- SLAC gateway ----------------------------------------------------------
SLAC_BASE_URL=https://ai-api.slac.stanford.edu
SLAC_API_KEY=
SLAC_MODEL_ALIAS=opus
SLAC_ANTHROPIC_DEFAULT_OPUS_MODEL=us.anthropic.claude-opus-4-6-v1
SLAC_ANTHROPIC_DEFAULT_SONNET_MODEL=us.anthropic.claude-sonnet-4-6
SLAC_ANTHROPIC_DEFAULT_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
SLAC_CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1

# ---- Stanford gateway ------------------------------------------------------
STANFORD_BASE_URL=https://aiapi-prod.stanford.edu
STANFORD_API_KEY=
# Stanford only sets SONNET (which routes to opus on their side); leave
# MODEL_ALIAS empty so we omit --model and let the SONNET default carry.
STANFORD_MODEL_ALIAS=
STANFORD_ANTHROPIC_DEFAULT_SONNET_MODEL=claude-4-6-opus
STANFORD_CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1
STANFORD_DISABLE_PROMPT_CACHING=1

# ---- Slack bridge (empty disables) -----------------------------------------
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_LLM_CHANNEL_ID=
SLACK_USERS_CHANNEL_ID=

# ---- Beamline runtime ------------------------------------------------------
SPEC_MOCK=1
# Valid options: tcp, screen, sandbox. Defaults to tcp if empty.
SPEC_TRANSPORT=tcp
# Sandbox API (Docker container running sim-mode SPEC).
# Used as transport when SPEC_MOCK=1 (with _MockScreen fallback)
# or when SPEC_TRANSPORT=sandbox.
SPEC_EVAL_URL=http://127.0.0.1:5006
BL_SCAN_DIR=
BL_LOGS_DIR=

# ---- Observability (MLflow tracing) ----------------------------------------
MLFLOW_ENABLED=0
MLFLOW_TRACKING_URI=https://isaac.slac.stanford.edu/mlflow/api/external
MLFLOW_TRACKING_TOKEN=
