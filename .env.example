# Autonomous Beamline Agent — environment overrides.
#
# This file holds only secrets and external IDs. Everything internal —
# port, paths, opencode location, timeouts — is hardcoded in
# server/config.py and does not belong here.

# ---- LLM (SLAC AI Gateway, used by opencode) ----
# Provision a key at https://ai-api.slac.stanford.edu and paste here.
SLAC_API_KEY=

# Optional model override. Defaults to Claude Opus 4.6 via the SLAC gateway.
# OPENCODE_MODEL=slac/us.anthropic.claude-opus-4-6-v1

# ---- Slack ----
# Empty values disable the bridge entirely (the app still runs).
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_LLM_CHANNEL_ID=
SLACK_USERS_CHANNEL_ID=

# ---- Beamline runtime overrides ----
# Default: SPEC_MOCK=1 (the app boots with a fully simulated SPEC + mock
# scan files, perfect for development on a laptop).
# On the actual beamline computer, flip these:
#   SPEC_MOCK=0
#   BL_SCAN_DIR=/data/fifteen
#   BL_LOGS_DIR=/usr/local/lib/spec.log/logfiles
# SPEC_MOCK=1
# BL_SCAN_DIR=
# BL_LOGS_DIR=
