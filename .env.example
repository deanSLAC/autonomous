# ---- LLM backend: opencode + SLAC AI Gateway ----
# Provision a SLAC AI Gateway key at https://ai-api.slac.stanford.edu and paste here.
SLAC_API_KEY=

# opencode server (started by scripts/start.sh, default :4096)
OPENCODE_URL=http://127.0.0.1:4096
OPENCODE_MODEL=slac/us.anthropic.claude-opus-4-6-v1
# Optional HTTP basic auth if opencode was started with credentials:
OPENCODE_USERNAME=
OPENCODE_PASSWORD=
OPENCODE_TIMEOUT_S=600
OPENCODE_HOST=127.0.0.1
OPENCODE_PORT=4096
# Point at a custom opencode install if not on $PATH / default path.
# OPENCODE_BIN=/path/to/opencode

# ---- FastAPI app ----
PORT=8080

# ---- Database ----
# Default: ./data/autonomous.db
# AUTONOMOUS_DB_PATH=

# ---- SPEC ----
SPEC_SCREEN_NAME=spec
SPEC_POLL_INTERVAL_S=2.0
SPEC_MOCK=0                     # 1 = simulate SPEC (no screen required)

# ---- Orchestrator ----
ORCHESTRATOR_ENABLED=1
ORCHESTRATOR_TICK_S=5
STATUS_POST_INTERVAL_S=900
DEFAULT_BEAMTIME_HOURS=48
BACKWARD_ONE_TIMEOUT_S=60
BACKWARD_MANY_TIMEOUT_S=30
GAP_REQUEST_TIMEOUT_S=900

# ---- Slack ----
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_LLM_CHANNEL_ID=
SLACK_USERS_CHANNEL_ID=
SLACK_STAFF_CHANNEL_ID=
